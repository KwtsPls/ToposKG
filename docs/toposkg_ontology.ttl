#################################################################
# Administrative hierarchy axioms
#################################################################

topos:hasUpperAdminUnit
    a owl:ObjectProperty, owl:FunctionalProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:label "has upper administrative unit"@en ;
    skos:definition "Links an administrative unit to its unique direct parent in the administrative hierarchy."@en ;
    rdfs:domain topos:AdministrativeUnit ;
    rdfs:range topos:AdministrativeUnit .

topos:AdministrativeUnit
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty topos:hasUpperAdminUnit ;
        owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
        owl:onClass topos:AdministrativeUnit
    ] .


#################################################################
# Natural feature disjointness axioms
#################################################################

topos:Sea
    owl:disjointWith topos:Waterbody ,
                     topos:Forest ,
                     topos:Mountain .

topos:Waterbody
    owl:disjointWith topos:Forest ,
                     topos:Mountain .

topos:Forest
    owl:disjointWith topos:Mountain .

#################################################################
# Top-level branch separation
#################################################################

topos:AdministrativeUnit
    owl:disjointWith topos:Natural .

topos:AdministrativeUnit
    owl:disjointWith topos:General .


#################################################################
# Administrative level restrictions
#################################################################

topos:AdminUnit_Level0
    rdfs:subClassOf topos:AdministrativeUnit ,
        [
            a owl:Restriction ;
            owl:onProperty topos:hasUpperAdminUnit ;
            owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass topos:AdministrativeUnit
        ] .

topos:AdminUnit_Level1
    rdfs:subClassOf topos:AdministrativeUnit ,
        [
            a owl:Restriction ;
            owl:onProperty topos:hasUpperAdminUnit ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass topos:AdminUnit_Level0
        ] .

topos:AdminUnit_Level2
