@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix topos: <http://toposkg.di.uoa.gr/ontology/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# OWL ontology declaration
#################################################################

<http://toposkg.di.uoa.gr/ontology/>
    a owl:Ontology ;
    dcterms:title "ToposKG ontology"@en ;
    dcat:landingPage <https://toposkg.di.uoa.gr/ontology/> . 

#################################################################
# Class declarations
#################################################################

geo:SpatialObject
    a rdfs:Class, owl:Class ;
    rdfs:isDefinedBy geo: ;
    skos:prefLabel "Spatial Object"@en ;
    skos:definition "Anything spatial (being or having a shape, position or an extent)."@en ;
    skos:note "Subclasses of this class are expected to be used for instance data."@en .

geo:Feature
    a rdfs:Class, owl:Class ;
    rdfs:isDefinedBy geo: ;
    skos:prefLabel "Feature"@en ;
    rdfs:subClassOf geo:SpatialObject ;
    owl:disjointWith geo:Geometry ;
    skos:definition "A discrete spatial phenomenon in a universe of discourse."@en ;
    skos:note "A Feature represents a uniquely identifiable phenomenon, for example a river or an apple. While such phenomena, and therefore the Features used to represent them, are bounded, their boundaries may be crisp, vague, and change with time. While discrete in nature, Features may be created from continuous observations, such as an isochrone that determines the region that can be reached by ambulance within 5 minutes."@en .

geo:Geometry
    a rdfs:Class, owl:Class ;
    rdfs:isDefinedBy geo: ;
    skos:prefLabel "Geometry"@en ;
    rdfs:subClassOf geo:SpatialObject ;
    owl:disjointWith geo:Feature ;
    skos:definition "A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS)."@en ;
    skos:note "Geometry can be used as a representation of the shape, extent or location of a Feature and may exist as a self-contained entity."@en .

topos:AdminUnit_Level0
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Zero"@en ;
    skos:definition "Administrative Division of Level type zero (0). Usually aligned with countries or autonomus administrative regions"@en .

topos:AdminUnit_Level1
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
     skos:prefLabel "Administrative Unit Level One"@en ;
    skos:definition "Administrative Division of Level type one (1). Usually aligned with provinces, counties or other large administrative regions"@en .

topos:AdminUnit_Level2
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Two"@en ;
    skos:definition "Administrative Division of Level type two (2). Usually aligned with distrcts, communes, cantons, or municipalities"@en .

topos:AdminUnit_Level3
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Three"@en ;
    skos:definition "Administrative Division of Level type three (3). Usually aligned with municipalities, villages and finer grained rural districts"@en .

topos:AdminUnit_Level4
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Four"@en ;
    skos:definition "Administrative Division of Level type four (4). Usually aligned with municipalities, villages and finer grained rural districts"@en .

topos:AdminUnit_Level5
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Five"@en ;
    skos:definition "Administrative Division of Level type five (5). Introduced for Compatibility purposes for specific countries"@en .

topos:AdminUnit_Level6
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Six"@en ;
    skos:definition "Administrative Division of Level type six (6). Introduced for Compatibility purposes for specific countries"@en .

topos:AdminUnit_Level7
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Seven"@en ;
    skos:definition "Administrative Division of Level type seven (7). Introduced for Compatibility purposes for specific countries"@en .

topos:AdminUnit_Level8
    a owl:Class ;
    rdfs:subClassOf topos:AdministrativeUnit ;
    skos:prefLabel "Administrative Unit Level Eight"@en ;
    skos:definition "Administrative Division of Level type eight (8). Introduced for Compatibility purposes for specific countries"@en .

topos:AdministrativeUnit
    a owl:Class ;
    rdfs:subClassOf topos:ToposKGFeature ;
    skos:prefLabel "Administrative Unit"@en ;
    skos:definition "Top level class for administrative Units"@en .

topos:Forest
    a owl:Class ;
    rdfs:subClassOf topos:Natural ;
    skos:prefLabel "Forest"@en ;
    skos:definition "Class representing forest and other wooded areas"@en .

topos:General
    a owl:Class ;
    rdfs:subClassOf topos:ToposKGFeature ;
    skos:prefLabel "General"@en ;
    skos:definition "A geospatial feature whose identity is primarily defined by human use, function, social convention, infrastructure, or cultural significance, rather than by administrative authority or natural geographic formation."@en .

topos:Mountain
    a owl:Class ;
    rdfs:subClassOf topos:Natural ;
    skos:prefLabel "Mountain"@en ;
    skos:definition "Class representing mountains, hills, mountain ranges etc."@en .

topos:Natural
    a owl:Class ;
    rdfs:subClassOf topos:ToposKGFeature ;
    skos:prefLabel "Mountain"@en ;
    skos:definition "Super class for natural resources available in ToposKG"@en .

topos:POI
    a owl:Class ;
    rdfs:subClassOf topos:General ;
    skos:prefLabel "Point-of-Interest"@en ;
    skos:definition "Class representing points-of-interest like stores, churches, museums, coffee shops, etc."@en .

topos:Sea
    a owl:Class ;
    rdfs:subClassOf topos:Natural ;
    skos:prefLabel "Sea"@en ;
    skos:definition "Class representing seas and ocean segments"@en .

topos:ToposKGFeature
    a owl:Class ;
    rdfs:subClassOf geo:Feature ;
    skos:prefLabel "ToposKG Feature"@en ;
    skos:definition "Top level class for the ToposKG ontology."@en .

topos:Waterbody
    a owl:Class ;
    rdfs:subClassOf topos:Natural ;
    skos:prefLabel "Water Body"@en ;
    skos:definition "Class representing all in-land water formations like lakes, rivers, stream etc."@en .

topos:WikidataLink
    a owl:Class ;
    skos:prefLabel "Wikidata Link"@en ;
    skos:definition "Direct links to wikidata resources"@en .


#################################################################
# OSM Generated Classes
#################################################################

topos:Lagoon
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Lagoon"@en ;
    skos:definition "A lagoon: a body of shallow sea water or brackish water separated from the sea by some form of barrier."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=lagoon" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=lagoon> .

topos:Lake
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Lake"@en ;
    skos:definition "A lake: A body of relatively still fresh or salt water."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=lake" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=lake> .

topos:Oxbow
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Oxbow"@en ;
    skos:definition "An oxbow lake: U-shaped body of water formed when a wide meander from the main stem of a river is cut off to create a lake."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=oxbow" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=oxbow> .

topos:Rapids
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Rapids"@en ;
    skos:definition "A fast-flowing, often turbulent, section of a watercourse such as a river, often containing exposed rocks or boulders. This tag is only for mapping rapids area. "@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=rapids" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=rapids> .

topos:River
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "River"@en ;
    skos:definition "The water area of a river."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=river" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=river> .

topos:Stream
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Stream"@en ;
    skos:definition "The water covered area of a stream: a naturally-formed watercourse which is narrower than a river."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=stream" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=stream> .

topos:Stream_pool
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Stream Pool"@en ;
    skos:definition "A stream pool; a small and usually deep collection of fresh water, occurring along a stream. Water velocity in the pool is typically much lower than in the stream. Frequently found below a waterfall. May be used as a swimming hole."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=stream_pool" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=stream_pool> .

topos:Basin
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Basin"@en ;
    skos:definition "An area of land artificially graded to hold water."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=basin" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=basin> .

topos:Ditch
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Ditch"@en ;
    skos:definition "Water covered area of a waterway=ditch - a linear waterbody serving as a barrier or for draining surrounding land. Should contain waterway=ditch way inside."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=ditch" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=ditch> .

topos:Canal
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Canal"@en ;
    skos:definition "A body of a canal, a man-made channel for water."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=canal" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=canal> .

topos:Drain
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Drain"@en ;
    skos:definition "The water covered area of a waterway=drain - an artificial waterway, lined with concrete or similar, used to carry superfluous water. Should contain waterway=drain way inside."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=drain" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=drain> .

topos:Fish_pass
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Fish Pass"@en ;
    skos:definition "The body of a fish pass for the fish to pass waterway dams or weirs. Should contain waterway=fish_pass way inside."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=fish_pass" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=fish_pass> .

topos:Harbour
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Harbour"@en ;
    skos:definition "A harbour is a sheltered body of water where ships, boats, and barges can be docked."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=harbour" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=harbour> .

topos:Lock
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Lock"@en ;
    skos:definition "A lock chamber outline: a part of river, canal or lake system, level of which can be manipulated."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=lock" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=lock> .

topos:Moat
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Moat"@en ;
    skos:definition "A deep, wide defensive ditch, normally filled with water, surrounding a fortified habitation."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=moat" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=moat> .

topos:Pond
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Pond"@en ;
    skos:definition "A pond: a body of standing water, man-made in most cases, that is usually smaller than a lake."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=pond" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=pond> .

topos:Reflecting_pool
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Reflecting Pool"@en ;
    skos:definition "A reflecting pool: a water feature found in gardens, parks, and at memorial sites. It usually consists of a shallow pool of water, undisturbed by fountain jets, for a calm reflective surface."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=reflecting_pool" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=reflecting_pool> .

topos:Reservoir
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Reservoir"@en ;
    skos:definition "A reservoir - An artificial body of water used to store water, usually formed by a dam over a natural water course to retain the water."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=reservoir" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=reservoir> .

topos:Wastewater
    a owl:Class ;
    rdfs:subClassOf topos:Waterbody ;
    skos:prefLabel "Wastewater"@en ;
    skos:definition "A clarifier/settling basin of a wastewater treatment plant."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "water=wastewater" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:water=wastewater> .

topos:Parking
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Parking"@en ;
    skos:definition "Parking is a place where people can park their vehicle."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=parking" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=parking> .

topos:Place_of_worship
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Place of Worship"@en ;
    skos:definition "All places of worship, independently of the religion or denomination, get the tag amenity=place_of_worship."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=place_of_worship" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=place_of_worship> .

topos:Restaurant
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Restaurant"@en ;
    skos:definition "Is applied to generally formal eating places with sit-down facilities selling full meals served by waiters and often licensed (where allowed) to sell alcoholic drinks."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=restaurant" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=restaurant> .

topos:Bench
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Bench"@en ;
    skos:definition "A place for people to sit, allowing room for one or more people. Benches are used for resting for a period of time. They can be particularly important to older people or those with restricted mobility who need a place to sit or lean while travelling. Additionally, benches are often used for everyday activities like reading or eating when a picnic table is not available."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=bench" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=bench> .

topos:Parking_space
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Parking Space"@en ;
    skos:definition "Use amenity=parking_space to map a single parking space on a parking lot. Mapping parking spaces is an addition, not a replacement, to mapping a whole parking lot with amenity=parking."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=parking_space" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=parking_space> .

topos:Fast_food
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Fast Food"@en ;
    skos:definition "amenity=fast_food is for places which offers self-service and take-away food."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=fast_food" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=fast_food> .

topos:School
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "School"@en ;
    skos:definition "Use amenity=school to identify a place where pupils, normally between the ages of about 6 and 18 are taught under the supervision of teachers."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=school" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=school> .

topos:Fuel
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Fuel"@en ;
    skos:definition "The fuel tag is used to map a fuel station, also known as a filling station, petrol station, gas station and petrol garage. It is the retail-type facility where motor vehicles can be refueled."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=fuel" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=fuel> .

topos:Bicycle_parking
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Bicycle Parking"@en ;
    skos:definition "The term bicycle parking refers to any parking space designed for bicycles, where one can leave a pedal cycle unattended in reasonable security. In cities and towns, these can often be found in front of shops or along streets; possibly in association with parking for motorized vehicles. Examples of specific forms include covered bike sheds and lockers, simple ground-anchored bike racks, or curvy artistic lumps of metal for chaining your bike to."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=bicycle_parking" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=bicycle_parking> .

topos:Shelter
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Shelter"@en ;
    skos:definition "The tag amenity=shelter is used to map several kinds of shelter: a small structure designed to protect against bad weather conditions."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=shelter" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=shelter> .

topos:Waste_basket
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Waste Basket"@en ;
    skos:definition "A waste basket is a single small container for depositing garbage that is easily accessible for pedestrians. It can also be called a rubbish bin, litter bin, trash can, or garbage can."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=waste_basket" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=waste_basket> .

topos:Bank
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Bank"@en ;
    skos:definition "The tag amenity=bank is used to map a bank branch: a financial establishment where customers can, among other services, deposit and withdraw money, take loans, make investments and transfer funds. This definition encompasses banks, credit unions, building societies, and other similar establishments. It does not include money lenders (use shop=money_lender) or financial offices that are not banks (use office=financial)."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=bank" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=bank> .

topos:Toilets
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Toilets"@en ;
    skos:definition "Use amenity=toilets to identify the location of a toilet open to the public. Public toilets are commonly referred to as restrooms, washrooms, bathrooms, or toiletrooms."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=toilets" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=toilets> .

topos:Grave_yard
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Graveyard"@en ;
    skos:definition "At places tagged with amenity=grave_yard people (or sometimes animals) were buried."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=grave_yard" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=grave_yard> .


topos:Waste_disposal
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Waste Disposal"@en ;
    skos:definition "Waste disposal is used for medium and large waste bins, typically for bagged up household or industrial waste. They may be in the street, but they are not primarily for use by passing pedestrians."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=waste_disposal" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=waste_disposal> .

topos:Cafe
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Cafe"@en ;
    skos:definition "amenity=cafe is for a generally informal place with sit-down facilities selling beverages and light meals and/or snacks. This includes coffee-shops and tea shops selling perhaps tea, coffee and cakes, through to bistros selling meals with alcoholic drinks."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=cafe" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=cafe> .

topos:Fire_station
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Fire Station"@en ;
    skos:definition "Used to tag an active fire station: a facility from which a fire brigade operates to fight fires."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=Fire_station" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=Fire_station> .

topos:Fountain
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Fountain"@en ;
    skos:definition "A fountain with cultural, decorative, or historical significance or which serves a recreational purpose."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=Fountain" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=Fountain> .

topos:Post_office
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Post Office"@en ;
    skos:definition "A post office which offers public-facing services such as sending or collecting letters or parcels, sale of stamps, ..."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=post_office" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=post_office> .

topos:Bar
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Bar"@en ;
    skos:definition "The tag amenity=bar is used to map a bar: a purpose-built commercial establishment that sells alcoholic drinks to be consumed on the premises. They are characterised by a noisy and vibrant atmosphere, similar to a party. They usually do not sell food to be eaten as a meal. The music is usually loud and you often have to stand. Sometimes it has a dancefloor, but it's not the main attraction."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=bar" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=bar> .

topos:Clinic
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Clinic"@en ;
    skos:definition "amenity=clinic is a medical centre, with more staff than a doctor's office, that does not admit inpatients. Typical clinic is a medical centres with 10 or more of doctors, nurses and associated staff. Clinics offer outpatient care, diagnosis, radiology, treatment, and sometimes urgent care. Admission of inpatients is not provided."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=clinic" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=clinic> .

topos:Pharmacy
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Pharmacy"@en ;
    skos:definition "A shop where a pharmacist sells medications. Such shops also called drugstores, especially in the United States."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=pharmacy" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=pharmacy> .

topos:Library
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Library"@en ;
    skos:definition "A library is a collection of books and other media that can be read and/or borrowed."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=library" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=library> .


topos:Vending_machine
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Vending Machine"@en ;
    skos:definition "A vending machine is a machine which dispenses items such as snacks, beverages, alcohol, cigarettes, lottery tickets, cologne, consumer products and even gold and gemstones to customers automatically, after the customer inserts currency or credit into the machine."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=vending_machine" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=vending_machine> .

topos:Doctors
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Doctors"@en ;
    skos:definition "A doctor's office is a place you can go to get medical attention or a check up from a physician; also known as a doctor's surgery in the UK. These range from a single doctor's office to larger outpatient facilities."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=doctors" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=doctors> .


topos:Police
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Police"@en ;
    skos:definition "A police station is a place that serves as a primary point of contact for the public, i.e. public-facing police facilities."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=police" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=police> .

topos:Community_centre
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Community Centre"@en ;
    skos:definition "Community centres are public locations where members of a community tend to gather for group activities, social support, informal and formal meetings, public information, events and festivities, and other purposes."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=community_centre" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=community_centre> .

topos:Townhall
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Townhall"@en ;
    skos:definition "Use this for a village, town or city townhall, which is often the seat of the mayor, or may be merely a community meeting place."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=townhall" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=townhall> .

topos:Recycling
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Recycling"@en ;
    skos:definition "Recycling is used for a container or centre that accepts waste material for recycling, and donations of used goods."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=recycling" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=recycling> .

topos:Atm
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Atm"@en ;
    skos:definition "An automated teller machine (ATM), or automatic banking machine (ABM), or 'cash machine', is a computerised telecommunications device that provides the clients of a financial institution with access to financial transactions in a public space without the need for a cashier, human clerk or bank teller."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=atm" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=atm> .

topos:Hospital
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Hospital"@en ;
    skos:definition "amenity=hospital is used for hospitals, i.e. institutions for health care providing treatment by specialised staff and equipment, and typically providing nursing care for longer-term patient stays."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=hospital" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=hospital> .

topos:Pub
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Pub"@en ;
    skos:definition "A pub or public house is an establishment that sells alcoholic drinks that can be consumed on, or off, the premises. Pubs often sell food which also can be eaten on the premises although 'Wet Pubs' which do not sell food are also are also common. They are characterised by a traditional appearance and a relaxed atmosphere. You can usually sit down and there is usually no loud music to disturb conversation. A pub would be a good location to meet after a day's mapping for OpenStreetMap."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=pub" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=pub> .


topos:Theatre
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Theatre"@en ;
    skos:definition "Used to tag a theatre where live performances occur, such as plays, musicals and formal concerts."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=theatre" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=theatre> .

topos:Veterinary
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Veterinary"@en ;
    skos:definition "A place where a veterinary surgeon, also known as a veterinarian or vet, practices. This can range from a small office to a large animal hospital. It is a place where there is a certified doctor that deals with the prevention, diagnosis and treatment of disease, disorder and injury in animals is stationed."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=veterinary" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=veterinary> .

topos:Veterinary
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Veterinary"@en ;
    skos:definition "A place where a veterinary surgeon, also known as a veterinarian or vet, practices. This can range from a small office to a large animal hospital. It is a place where there is a certified doctor that deals with the prevention, diagnosis and treatment of disease, disorder and injury in animals is stationed."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=veterinary" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=veterinary> .

topos:Cinema
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Cinema"@en ;
    skos:definition "Used to tag a cinema - a place showing movies (films), generally open to the public for a fee. Commonly referred to as a movie theater in the US."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=cinema" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=cinema> .

topos:University
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "University"@en ;
    skos:definition "The tag amenity=university is used to map a university: an institution of higher education, designed for instruction, examination, or both, of students in many branches of advanced learning."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=university" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=university> .

topos:Marketplace
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Marketplace"@en ;
    skos:definition "The tag amenity=marketplace is used to map a public marketplace where goods and services are traded daily or weekly."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=marketplace" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=marketplace> .

topos:Studio
    a owl:Class ;
    rdfs:subClassOf topos:POI ;
    skos:prefLabel "Studio"@en ;
    skos:definition "A studio used for creating radio or television programmes and broadcasting them. It can also be used to mark a music recording studio."@en ;
    dcterms:source <https://www.openstreetmap.org/> ;
    topos:osmTag "amenity=studio" ;
    rdfs:isDefinedBy <https://wiki.openstreetmap.org/wiki/Tag:amenity=studio> .

#################################################################
# ToposKG core
#################################################################

geo:hasGeometry
    a rdf:Property, owl:ObjectProperty ;
    rdfs:isDefinedBy geo: ;
    skos:prefLabel "has Geometry"@en ;
    skos:definition "A spatial representation for a given Feature."@en ;
    rdfs:domain geo:Feature ;
    rdfs:range geo:Geometry .

geo:asWKT
    a rdf:Property, owl:DatatypeProperty ;
    rdfs:isDefinedBy geo: ;
    skos:prefLabel "as WKT"@en ;
    skos:definition "The WKT serialization of a Geometry."@en ;
    rdfs:domain geo:Geometry ;
    rdfs:range geo:wktLiteral ;
    rdfs:subPropertyOf geo:hasSerialization .

topos:hasArea
    a owl:DatatypeProperty ;
    rdfs:label "area"@en ;
    skos:definition "Area associated with a ToposKG geospatial feature."@en ;
    rdfs:domain topos:ToposKGFeature ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasDescription
    a owl:DatatypeProperty ;
    rdfs:label "description"@en ;
    skos:definition "Textual description associated with a ToposKG feature."@en ;
    rdfs:domain topos:ToposKGFeature ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasISO3Code
    a owl:DatatypeProperty ;
    rdfs:label "iso 3 code"@en ;
    skos:definition "ISO 3166-1 alpha-3 country code associated with an administrative unit."@en ;
    rdfs:domain topos:AdministrativeUnit ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasMRGID
    a owl:DatatypeProperty ;
    rdfs:label "mrgid"@en ;
    skos:definition "MarineRegions Gazetteer identifier associated with a sea feature."@en ;
    rdfs:domain topos:Sea ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasMountainLevel
    a owl:DatatypeProperty ;
    rdfs:label "mountain level"@en ;
    skos:definition "Level or granularity descriptor associated with a mountain feature."@en ;
    rdfs:domain topos:Mountain ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasName
    a owl:DatatypeProperty ;
    rdfs:label "name"@en ;
    skos:definition "Human-readable name associated with a ToposKG feature."@en ;
    rdfs:domain topos:ToposKGFeature ;
    rdfs:range xsd:double ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:hasUpperAdminUnit
    a owl:ObjectProperty ;
    rdfs:label "upper admin unit"@en ;
    skos:definition "Links an administrative unit to a broader administrative unit in the ToposKG administrative hierarchy."@en ;
    rdfs:domain topos:AdministrativeUnit ;
    rdfs:range topos:AdministrativeUnit ;
    rdfs:subPropertyOf owl:topObjectProperty .

topos:hasUpperMountain
    a owl:ObjectProperty ;
    rdfs:label "upper mountain"@en ;
    skos:definition "Links a mountain feature to a broader mountain or mountain range entity."@en ;
    rdfs:domain topos:Mountain ;
    rdfs:range topos:Mountain ;
    rdfs:subPropertyOf owl:topObjectProperty .

topos:hasWikidataLink
    a owl:ObjectProperty ;
    rdfs:label "wikidata link"@en ;
    skos:definition "Link from a ToposKG feature to an associated Wikidata resource."@en ;
    rdfs:domain topos:ToposKGFeature ;
    rdfs:range topos:WikidataLink,
        topos:WikidataURL ;
    rdfs:subPropertyOf owl:topObjectProperty .

topos:inContinent
    a owl:DatatypeProperty ;
    rdfs:label "in continent"@en ;
    skos:definition "Associates a mountain feature with the continent in which it is located."@en ;
    rdfs:domain topos:Mountain ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

topos:inCountry
    a owl:DatatypeProperty ;
    rdfs:label "in country"@en ;
    skos:definition "Associates a mountain feature with the country in which it is located."@en ;
    rdfs:domain topos:Mountain ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf owl:topDataProperty .

#################################################################
# OSM alignment annotation-property declarations
#################################################################

topos:osmKey
    a owl:AnnotationProperty ;
    rdfs:label "OSM key"@en ;
    skos:definition "OpenStreetMap key aligned with a ToposKG predicate."@en .

topos:osmTag
    a owl:AnnotationProperty ;
    rdfs:label "OSM tag"@en ;
    skos:definition "OpenStreetMap key/value tag or wildcard key alignment."@en .

topos:osmValue
    a owl:AnnotationProperty ;
    rdfs:label "OSM value"@en ;
    skos:definition "OpenStreetMap value aligned with a ToposKG predicate when the mapping is key=value."@en .

